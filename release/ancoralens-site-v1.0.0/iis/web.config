<?xml version="1.0" encoding="UTF-8"?>
<!--
  AncoraLens — IIS reverse-proxy site config (RECOMMENDED approach).

  IIS receives traffic on :80/:443 and forwards everything to the AncoraLens
  Node service running on http://localhost:8080. The Node server serves both the
  UI and the /api endpoints, so IIS only handles TLS, the hostname, and the port.

  Requires on the server (one-time):
    • IIS "URL Rewrite" module      https://www.iis.net/downloads/microsoft/url-rewrite
    • IIS "Application Request Routing" (ARR)  https://www.iis.net/downloads/microsoft/application-request-routing
    • ARR proxy ENABLED at the server level (IIS Manager → server node →
      "Application Request Routing Cache" → "Server Proxy Settings" → check
      "Enable proxy").  setup-iis.ps1 enables it for you.

  Place this web.config in the IIS site's physical path (any folder is fine — all
  requests are proxied to Node regardless of folder contents).
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="AncoraLens-ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:8080/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Allow large CSV/context payloads to pass through to Node (50 MB). -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

    <!-- Don't let IIS serve or cache anything itself; Node owns all responses. -->
    <caching enabled="false" />
    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
