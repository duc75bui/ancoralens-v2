<?xml version="1.0" encoding="UTF-8"?>
<!--
  AncoraLens — ALTERNATIVE: run Node *inside* IIS via the iisnode module.
  Use this ONLY if your org requires iisnode instead of the reverse-proxy approach.

  To use:  rename this file to "web.config", place it at the IIS site ROOT (the
  bundle root, where dist/ and server/ live), install iisnode
  (https://github.com/Azure/iisnode/releases), install the server production deps
  (run "npm ci" with the omit-dev flag inside server\), and create the IIS site /
  app pool (No Managed Code).

  iisnode launches `node server/index.js` and routes all requests to it; the Express
  app then serves dist/ and /api. No separate Windows service or port is needed.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="server/index.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Route every request into the Node app (it serves UI + API itself). -->
        <rule name="AncoraLens-iisnode">
          <match url=".*" />
          <action type="Rewrite" url="server/index.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCommandLine="&quot;C:\Program Files\nodejs\node.exe&quot;"
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      devErrorsEnabled="false" />

    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
        <!-- keep the server/ source from being served as static files -->
        <hiddenSegments>
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
