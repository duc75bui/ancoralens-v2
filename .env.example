# AncoraLens server configuration
# Copy this file to ".env" is NOT required — these are plain OS environment variables
# the server reads at startup. Set them in your service definition (NSSM / systemd)
# or the shell before running `node server/index.js`.

# Port the unified server listens on (serves both the UI and /api).
PORT=8080

# --- Notes ---
# • Gemini API keys are entered by users in the AI Assistant UI and stored only in
#   their browser (localStorage). They are NOT read from the server environment.
# • SQL connection strings are entered by users in the SQL Connector UI per request.
#   Nothing is persisted server-side.
